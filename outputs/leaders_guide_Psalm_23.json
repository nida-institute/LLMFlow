"[\n  {\n    \"Scene number\": \"Scene 1\",\n    \"Citation\": \"Psalm 23:1\",\n    \"Title\": \"The Lord is my shepherd\",\n    \"Berean Standard Bible\": \"The LORD is my shepherd; I shall not want.\",\n    \"WLC\": \"מִזְמוֹר לְדָוִד יְהוָה רֹעִי לֹא אֶחְסָֽר׃\"\n  },\n  {\n    \"Scene number\": \"Scene 2\",\n    \"Citation\": \"Psalm 23:2\",\n    \"Title\": \"Green pastures and still waters\",\n    \"Berean Standard Bible\": \"He makes me lie down in green pastures; He leads me beside quiet waters.\",\n    \"WLC\": \"בִּנְאוֹת דֶּשֶׁא יַרְבִּיצֵנִי עַל מֵי מְנֻחוֹת יְנַהֲלֵֽנִי׃\"\n  },\n  {\n    \"Scene number\": \"Scene 3\",\n    \"Citation\": \"Psalm 23:3\",\n    \"Title\": \"Restoration and guidance\",\n    \"Berean Standard Bible\": \"He restores my soul; He guides me in the paths of righteousness for His name’s sake.\",\n    \"WLC\": \"נַפְשִׁי יְשׁוֹבֵב יַנְחֵנִי בְּמַעְגְּלֵי צֶדֶק לְמַֽעַן שְׁמוֹ׃\"\n  },\n  {\n    \"Scene number\": \"Scene 4\",\n    \"Citation\": \"Psalm 23:4\",\n    \"Title\": \"Through the valley of the shadow of death\",\n    \"Berean Standard Bible\": \"Even though I walk through the valley of the shadow of death, I will fear no evil, for You are with me; Your rod and Your staff, they comfort me.\",\n    \"WLC\": \"גַּם כִּי אֵלֵךְ בְּגֵיא צַלְמָוֶת לֹא־אִירָא רָע כִּי אַתָּה עִמָּדִי שִׁבְטְךָ וּמִשְׁעַנְתֶּךָ הֵמָּה יְנַחֲמֻנִי׃\"\n  },\n  {\n    \"Scene number\": \"Scene 5\",\n    \"Citation\": \"Psalm 23:5\",\n    \"Title\": \"A table prepared in the presence of enemies\",\n    \"Berean Standard Bible\": \"You prepare a table before me in the presence of my enemies. You anoint my head with oil; my cup overflows.\",\n    \"WLC\": \"תַּעֲרֹךְ לְפָנַי שֻׁלְחָן נֶגֶד צֹרְרָי דִּשַּׁנְתָּ בַשֶּׁמֶן רֹאשִׁי כּוֹסִי רְוָיָֽה׃\"\n  },\n  {\n    \"Scene number\": \"Scene 6\",\n    \"Citation\": \"Psalm 23:6\",\n    \"Title\": \"Goodness and mercy follow\",\n    \"Berean Standard Bible\": \"Surely goodness and mercy will follow me all the days of my life, and I will dwell in the house of the LORD forever.\",\n    \"WLC\": \"אַךְ טוֹב וָחֶסֶד יִרְדְּפוּנִי כָּל־יְמֵי חַיַּי וְשַׁבְתִּי בְּבֵית־יְהוָה לְאֹרֶךְ יָמִֽים׃\"\n  }\n]"