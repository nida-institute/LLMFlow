# Ignore output files
outputs/
*.out
*.log

# Ignore swap and temp files (Vim, etc.)
*.swp
*.swo
*.swn
*~

# Ignore editor-specific files
.DS_Store
.vscode/
.idea/

# Ignore virtual environments
.venv/
env/
venv/

# Ignore compiled Python files
__pycache__/
*.pyc
*.pyo

# Ignore Hatch's build artifacts
dist/
build/
.eggs/
*.egg-info/

# Optional: ignore large or temporary input files
# You can whitelist specific files to keep
inputs/**/*.bak
inputs/**/*.tmp
inputs/**/*.xml~   # Backup-style XMLs

# VSCode workspace settings (these are personal preferences)
.vscode/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
*.cover

# LLMFlow specific
pseaf.txt  # This seems to be a temp/test file
outputs/   # If not already there
*.log
llmflow.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Environment
.env
.env.local
*.env

